<div data-section-id="{{ section.id }}" data-section-type="header-section">
  <header role="banner" class="bg-yellow bn ba-l bw4-l b--white">
    {% if section.settings.share == true %}
      {% if settings.share_facebook or settings.share_twitter or settings.share_pinterest %}
      <center class="bg-light-green w-100 dt ma0 center">
        <div class="dtc v-mid tl ph4 pv5">
        {% include 'social-sharing' %}
        </div>
      </center>
      {% endif %}
    {% endif %}
    <section class="w-100 vh-100 vh-75-l dt ma0 center">
      <center class="dtc v-mid tl ph4 pv5">

        {% if template.name == 'index' or template.name == 'password' %}
        <h1 class="cursor ma0 f1 f-subheadline-m f-headline-l lh-title tracked-tight" itemscope itemtype="http://schema.org/Organization">
        {% else %}
        <div class="cursor b ma0 f1 f-subheadline-m f-headline-l lh-title tracked-tight" itemscope itemtype="http://schema.org/Organization">
        {% endif %}

          <a href="/" itemprop="url" class="site-logo link no-underline dark-gray ttc{% if section.settings.logo != blank %} site-header__logo-image{% endif %}">

          {% if section.settings.logo != blank %}
          {% capture image_size %}{{ section.settings.logo_max_width }}x{% endcapture %}
            <img src="{{ section.settings.logo | img_url: image_size }}"
                 srcset="{{ section.settings.logo | img_url: image_size }} 1x, {{ section.settings.logo | img_url: image_size, scale: 2 }} 2x"
                 alt="{{ section.settings.logo.alt | default: shop.name }}"
                 itemprop="logo">
          {% else %}

            {{ shop.name }}

          {% endif %}

          </a>

        {% if template.name == 'index' %}
        </h1>
        {% else %}
        </div>
        {% endif %}

        {% if template.name == 'password' %}
        <h2 class="b ma0 f3 f2-m f1-l lh-title tracked-tight">{{ 'general.password_page.opening_soon' | t }}</h2>
        {% else %}
        <h2 class="normal f3 f2-ns lh-title">{{ section.settings.quote | escape }}</h2>
        {% endif %}

        <address class="fs-normal wow animated fadeInUp">
          <ul class="list pa0 mv4 lh-copy">
            <li class="dib mr2"><a class="link underline-hover dark-gray" href="mailto:hello@studiocraft.cc"><abbr title="Email"><i class="fa fa-fw fa-envelope" aria-hidden="true"></i></abbr>hello@studiocraft.cc</a></li>
            <li class="dib mr2"><a class="link underline-hover dark-gray" href="tel:13472211926"><abbr title="Phone"><i class="fa fa-fw fa-phone" aria-hidden="true"></i></abbr>(347) 221-1926</a></li>
            <li class="dib mr2"><a class="link underline-hover dark-gray" href="https://goo.gl/maps/ePAZK239wrC2" target="_blank"><abbr title="Location"><i class="fa fa-fw fa-globe" aria-hidden="true"></i></abbr>Brooklyn, NY</a></li>
          </ul>
        </address>
      </center>
    </section>
  </header>
</div>

{% schema %}
  {
    "name": "Banner",
    "settings": [
      {
        "type": "textarea",
        "id": "quote",
        "label": "Quote",
        "default": "An independent design studio and shop."
      }
    ]
  }
{% endschema %}
