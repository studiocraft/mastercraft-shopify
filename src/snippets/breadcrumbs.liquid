{% unless template == 'index' %}
<div role="header" class="bg-washed-green w-100 dt ma0 center">
  <nav class="breadcrumb dtc v-mid tl ph4 pv3" role="navigation" aria-label="breadcrumbs" class="wow animated fadeInDown">
    <ul class="list pa0 mv0">
      <li class="dib">
        <a class="link underline-hover dark-gray" href="/">{{ shop.name }}</a>
        <span aria-hidden="true">/</span>
      </li>
      {% if template contains 'page' %}
      <li class="dib">
        <span>{{ page.title }}</span>
      </li>

      {% elsif template contains 'product' %}
      <li class="dib">
        {% if collection.url %}
          <a class="link underline-hover dark-gray" href="{{ collection.url }}">{{ collection.title }}</a>
        {% endif %}
        <span aria-hidden="true">/</span>

        <span class="dark-gray">{{ product.title }}</span>
      </li>

      {% elsif template contains 'collection' and collection.handle %}
      <li class="dib">
        {% if current_tags %}
          {% capture url %}/collections/{{ collection.handle }}{% endcapture %}
          <a class="link underline-hover dark-gray" href="{{ url }}">{{ collection.title }}</a>
          <span aria-hidden="true">/</span>

          <span>{{ current_tags | join: " + " }}</span>
          {% else %}
          <span>{{ collection.title }}</span>
        </li>
        {% endif %}

      {% elsif template == 'blog' %}
        <span aria-hidden="true">/</span>
        {% if current_tags %}
          {{ blog.title | link_to: blog.url }}
          <span aria-hidden="true">/</span>
          <span>{{ current_tags | join: " + " }}</span>
        {% else %}
        <span>{{ blog.title }}</span>
        {% endif %}

      {% elsif template == 'article' %}
        <span aria-hidden="true">/</span>
        {{ blog.title | link_to: blog.url }}
        <span aria-hidden="true">/</span>
        <span>{{ article.title }}</span>
      {% else %}
       <span class="dark-gray">{{ page_title }}</span>

    {% endif %}

    </ul>

  </nav>
</div>
{% endunless %}
